{
    "name": "NovaEco Website",
    "image": "ghcr.io/novaeco-tech/novaeco-dev-unified:v0.1.0",
    "customizations": {
        "vscode": {
            "extensions": [
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint"
            ]
        }
    },
    "remoteEnv": {
        "PATH": "${containerEnv:PATH}:/home/node/.local/bin"
    },
    "forwardPorts": [3000],
    "postCreateCommand": "npm install && pip install --break-system-packages 'git+ssh://git@github.com/novaeco-tech/novaeco-devtools.git@v0.1.0#subdirectory=novaeco-cli'"
}